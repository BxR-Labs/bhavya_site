# Adding PC No to the AE data
pcdf <- tcd %>%
dplyr::filter(Year >= 2008) %>%
dplyr::filter(!State_Name %in% c("Andhra_Pradesh")) %>% #since AP has changes in PC / AC Nos pre and post break up into TS
dplyr::distinct(State_Name,PC_No,Constituency_No)
pcdf_ap <- tcd %>%
dplyr::filter(Year >= 2008) %>%
dplyr::mutate(pre_break_up = ifelse(Year <= 2014,1,0)) %>% #general elections data has telangana defined 2019 onwards
dplyr::filter(State_Name %in% c("Andhra_Pradesh")) %>%
dplyr::distinct(State_Name,PC_No,Constituency_No,pre_break_up)
tcd_ae <- left_join(tcd_ae,
pcdf,
by = c("State_Name","Constituency_No"))
tcd_ae <- left_join(tcd_ae %>%
dplyr::mutate(pre_break_up = ifelse(Year < 2014,1,0)), #CMIE and TCPD have different TS definitions
pcdf_ap,
by = c("State_Name","Constituency_No","pre_break_up"))
tcd_ae <- tcd_ae  %>%
dplyr::mutate(PC_No = ifelse(is.na(PC_No.x),
PC_No.y,
PC_No.x) )%>%
dplyr::select(-c(pre_break_up,PC_No.x,PC_No.y))
rm(pcdf,pcdf_ap)
# Appending data
fin_df <- bind_rows(tcd %>%
dplyr::mutate(across(c("Year"),
~ as.numeric(.))),
