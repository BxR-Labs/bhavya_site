#                      ~gsub("[()]", "", .))) #%>% #removing characters in parenthesis
# dplyr::mutate(across(c("Constituency_Name_new"),
#                      ~gsub("\\s", "", .))) #removing white spaces
temp <- left_join(temp,
cmie_ae %>%
dplyr::filter(merge == 1) %>%
dplyr::select(c(State_Name, Constituency_No,merge,Year)),
by = c("State_Name", "Constituency_No","Year"))
non_matched_tcd <- temp %>%
dplyr::filter(is.na(merge))
# Ideally,I want to edit the names and remove (st), (sc),(s.t.). However, because the data no more remains unique when I do this, I will only edit for (s.t.)
non_matched_tcd <- non_matched_tcd %>%
dplyr::mutate(Brackets_Content = str_extract(Constituency_Name, "\\(.*?\\)")) %>%
dplyr::mutate(Constituency_Name_new = case_when(
#Brackets_Content == "(sc)" ~ str_replace(Constituency_Name_new, "\\s*sc\\b", ""),
#Brackets_Content == "(st)" ~ str_replace(Constituency_Name_new, "\\s*st\\b", ""),
Brackets_Content == "(s.t.)" ~ str_replace(Constituency_Name_new, "\\s*s\\.t\\.\\b", ""),
TRUE ~ Constituency_Name_new
)) %>%
dplyr::select(-c(Constituency_Name,merge,Brackets_Content))
# dplyr::mutate(across(c("Constituency_Name"),
#                      ~ str_replace_all(.," \\(SC\\)| \\(ST\\)",""))) %>% # removing SC and ST from the name for better matching
# Fuzzy matching
#manually checked the matches and they are perfect (and matched all valid matches (removing non-evm vote cases etc))
data <- stringdist_join(non_matched %>%
dplyr::distinct(State_Name,Constituency_Name_new,.keep_all = TRUE) %>%
dplyr::select(-Year),
non_matched_tcd %>%
dplyr::distinct(State_Name,Constituency_Name_new,.keep_all = TRUE) %>%
dplyr::select(-Year),
by = c("State_Name","Constituency_Name_new"),
mode = "left",
ignore_case = FALSE,
method = "jw",
max_dist = 99,
distance_col = "dist") %>%
dplyr::filter(State_Name.dist == 0) %>% #keeping only perfect state matches
dplyr::group_by(State_Name.x,Constituency_Name_new.x) %>%
slice_min(order_by = Constituency_Name_new.dist, n = 1) %>%
dplyr::ungroup()
data$srno = 1:nrow(data)
# manually going over the matches
# Exporting non-perfect matches for manual checking and correction
toedit_ac <- data %>%
dplyr::select(State_Name.x, Constituency_Name,Constituency_Name_new.x,
Constituency_Name_new.y,
Constituency_No, merge,
Constituency_Name_new.dist,srno) %>%
dplyr::rename(State_Name = State_Name.x) %>%
dplyr::mutate(keep_matched = NA,
new_AC_no = NA) %>%
dplyr::arrange(State_Name, Constituency_Name_new.x)
# write_xlsx(toedit_ac,
#            paste0(data_filepath,
#                   "Working/fuzzy_matching/AE_CMIE_TCD_Data_For_Editing_Raw.xlsx"))
# reading in the data
data_new <- readxl::read_excel(paste0(data_filepath,
"Working/fuzzy_matching/AE_CMIE_TCD_Data_For_Editing_working.xlsx"))
data_new <- data_new %>%
dplyr::filter(!(keep_matched == 0 & is.na(new_AC_no))) %>% #dropping duplicated rows which are incorrect
dplyr::mutate(new_Constituency_No = ifelse(keep_matched == 0,
new_AC_no,
Constituency_No)) %>%
dplyr::select(State_Name,Constituency_Name,merge,new_Constituency_No)
cmie_ae <- left_join(cmie_ae,
data_new,
by = c("Constituency_Name","State_Name","merge"))
cmie_ae <- cmie_ae %>%
dplyr::mutate(Constituency_No = ifelse(merge ==0,
new_Constituency_No,
Constituency_No))
# Finally, merging in CMIE data to TCD
#check for cmie_ae duplicates in constituency_No and correcting them
cmie_ae <- cmie_ae %>%
dplyr::filter(!((Year %in% c(2011,2016) &
State_Name == "Tamil_Nadu" &
Constituency_Name == "tirupattur") | #this is duplicated - checked no of electors and they are the same as tirupattur vellore
Year == 2008 &
State_Name == "Jammu_&_Kashmir" &
Constituency_Name == "ranbirsinghpura"))  %>% #this is duplicated - checked no of electors and they are the same as r.s.pura
dplyr::mutate(Constituency_No = case_when(State_Name == "Andhra_Pradesh" &
Year %in% c(2014,2019) &
Constituency_Name %in% c("madugula",
"anakapalle",
"payakaraopet") ~ Constituency_No - 119,
State_Name == "Andhra_Pradesh" &
Year %in% c(2009) &
Constituency_Name %in% c("pallakolu") ~ Constituency_No + 119,
State_Name == "Tamil_Nadu" &
Year == 2021 &
Constituency_Name == "tirupattur" ~ 185, # checked this manually - it is sivaganga
TRUE ~ Constituency_No))
# Finally merging the datasets
tcd_ae <- left_join(tcd_ae,
cmie_ae %>%
dplyr::select(-c(Constituency_Name,Constituency_Name_new,merge)),
by = c("Year","State_Name","Constituency_No"))
# Since 2018 data for Mizoram is missing, merging it in
tcd_ae <- left_join(tcd_ae %>%
dplyr::mutate(Year = as.character(Year)),
miz %>%
dplyr::mutate(State_Name = "Mizoram",
across(c("election_year"),
~as.character(.))) %>%
dplyr::rowwise() %>%
dplyr::mutate(Electors = sum(electors_women,
electors_men,
electors_other,
na.rm = TRUE)) %>%
dplyr::ungroup() %>%
dplyr::rename_with(~ paste0("miz_", .),
c("electors_women", "electors_men", "electors_other","Electors")) %>%
dplyr::rename(c(Year = election_year,
Constituency_No = A3)) %>%
dplyr::select(starts_with(c("Year","State","Consti","miz_"))),
by = c("Year","State_Name","Constituency_No"))
tcd_ae <- tcd_ae %>%
dplyr::mutate(Year = as.numeric(Year),
total_electors_ac_male = ifelse(State_Name == "Mizoram" &
Year == 2018,
miz_electors_men,
total_electors_ac_male),
total_electors_ac_female = ifelse(State_Name == "Mizoram" &
Year == 2018,
miz_electors_women,
total_electors_ac_female),
Electors = ifelse(State_Name == "Mizoram" &
Year == 2018,
miz_Electors,
Electors)) %>%
dplyr::select(-starts_with("miz_"))
# Identifying how many polling dates are missing
#%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
sub <- tcd_ae %>%
dplyr::filter(is.na(`Poll Date`)) %>%
dplyr::distinct(State_Name,Year,Constituency_No,Constituency_Name) %>%
dplyr::mutate(poll_date = NA) %>%
dplyr::arrange(State_Name,Year,Constituency_No,Constituency_Name)
# write_xlsx(sub,
#            paste0(data_filepath,
#                   "Raw/Elections/election_dates/assembly/AE_unmatched_dates_Raw.xlsx"))
sub_new <- read.csv(paste0(data_filepath,
"Raw/Elections/election_dates/assembly/AE_unmatched_dates_working.csv"))
# Convert the corrected dates to Date format
sub_new <- sub_new %>%
mutate(poll_date = as.Date(poll_date, format = "%d/%m/%Y"),
poll_date = format(poll_date, "%d-%b-%y")) %>%
dplyr::rename(State_Name = `ï..State_Name`)
# Adjusting Poll Date format
# Convert tcd_ae Poll Date to Date format
tcd_ae$`Poll Date` <- as.Date(as.character(tcd_ae$`Poll Date`), format = "%Y%m%d")
# Format the date to match the tcd Poll Date format
tcd_ae$`Poll Date` <- format(tcd_ae$`Poll Date`, format = "%d-%b-%y")
# Merging
#%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
tcd_ae <- left_join(tcd_ae,
sub_new %>%
dplyr::select(-Constituency_Name),
by = c("Year","State_Name","Constituency_No"))
tcd_ae <- tcd_ae %>%
dplyr::mutate(`Poll Date` = ifelse(is.na(`Poll Date`),
poll_date,
`Poll Date`)) %>%
dplyr::select(-poll_date)
# renaming var
tcd_ae <- tcd_ae %>%
dplyr::rename(total_electors_ac = Electors)
#%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
# Saving Datasets
#%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
# Saving the dataset
saveRDS(tcd_ae,
paste0(data_filepath,
"working/assembly_elections_working.RDS"))
rm(list = ls(pattern = "^cmie"))
rm(list = ls(pattern = "^non_"))
rm(list = ls(pattern = "^sub"))
rm(list = ls(pattern = "^t"))
rm(data,data_new,miz)
