# install_github("ropensci/MODIStsp")
if(!require("pacman")) install.packages("pacman")
pacman::p_load(
plyr, tidyverse, xtable, stringr, haven,
writexl, viridis, ggplot2, lfe, did, raster,
remotes, MODIStsp, rgeoboundaries, sf, did2s,
DescTools, dplyr
)
#sf::sf_use_s2(FALSE)
## Setting file paths for each user
# Bhavya Srivastava
if (Sys.getenv("USERNAME")== "Bhavya"){
main_dp_path  <- "C:/Users/Bhavya/Dropbox/Projects/Heat and Indian Elections/"
code_filepath <- paste0(main_dp_path,"1_input/code/")
data_filepath <- paste0(main_dp_path,"1_input/data/")
out_filepath  <- paste0(main_dp_path,"3_output/")
}
#%%%%%%%%%%%%%%%%%%%%%
# 1. Load Data
#%%%%%%%%%%%%%%%%%%%%%
e_df <- readRDS(paste0(data_filepath,
"working/all_elections_working.RDS"))
cdf <- read_dta(paste0(data_filepath,
"unweighted_weather_panel.dta"))
# https://www.wpc.ncep.noaa.gov/html/heatindex_equation.shtml
#%%%%%%%%%%%%%%%%%%%%%
# 2. Cleaning Data
#%%%%%%%%%%%%%%%%%%%%%
cdf$state_code <- as_factor(cdf$state_code) #Obtaining the encoded names
cdf <- cdf %>%
dplyr::mutate(state_code = str_replace_all(state_code, " ", "_")) %>%
dplyr::mutate(state_code = ifelse(state_code == "Orissa",
"Odisha",
state_code)) %>%
dplyr::rename(c(State_Name = state_code,
standard_ac_id = ac,
standard_pc_id = pc,
`Poll Date` = date))
cdf$`Poll Date` <- format(as.Date(cdf$`Poll Date`), "%d-%b-%y")
# keeping post delim
cdf <- cdf %>%
dplyr::mutate(Year = ifelse(substr(as.character(`Poll Date`),8,9) == 99,
1999,
as.numeric(paste0("20",
substr(as.character(`Poll Date`),
8,
9))))) %>%
dplyr::filter(Year >= 2008) %>%
dplyr::select(-Year)
gc(reset = TRUE)
e_df <- e_df %>%
dplyr::filter(Year >= 2008)
fin_df <- left_join(e_df %>%
dplyr::mutate(State_Name = ifelse((State_Name == "Telangana" &
Year == 2019 &
Election_Type == "Lok Sabha Election (GE) (AC Segment Wise)") |
(State_Name == "Telangana" &
Year >= 2014 &
Election_Type == "State Assembly Election (AE)"),
"Andhra_Pradesh",
State_Name)),
cdf %>%
dplyr::mutate(`Poll Date` = as.character(`Poll Date`)) %>%
dplyr::select(-standard_pc_id),
by = c("standard_ac_id","Poll Date","State_Name")) #PCIDs don't match. investigate
# Adjusting Telangana data
fin_df <- fin_df %>%
dplyr::mutate(State_Name = ifelse(((State_Name == "Andhra_Pradesh" &
Year == 2019 &
Election_Type == "Lok Sabha Election (GE) (AC Segment Wise)") |
(State_Name == "Andhra_Pradesh" &
Year %in% c(2014,2019) &
Election_Type == "State Assembly Election (AE)")) &
standard_ac_id == Constituency_No,
"Telangana",
State_Name))
# Generating the heat index
# source: https://www.wpc.ncep.noaa.gov/html/heatindex_equation.shtml
fin_df <- fin_df %>%
dplyr::mutate(t2m_max_f = (t2m_max * 9/5) + 32,
hidx_base = -42.379 + 2.04901523*t2m_max_f +
10.14333127*relative_humidity -
.22475541*t2m_max_f*relative_humidity -
.00683783*t2m_max_f*t2m_max_f -
.05481717*relative_humidity*relative_humidity +
.00122874*t2m_max_f*t2m_max_f*relative_humidity +
.00085282*t2m_max_f*relative_humidity*relative_humidity -
.00000199*t2m_max_f*t2m_max_f*relative_humidity*relative_humidity,
hidx_adj = case_when(relative_humidity < 13 &
t2m_max_f >80 &
t2m_max_f < 112 ~ ((13-relative_humidity)/4)*sqrt((17-abs(t2m_max_f-95))/17),
relative_humidity > 85 &
t2m_max_f >80 &
t2m_max_f < 87 ~ ((relative_humidity-85)/10) * ((87-t2m_max_f)/5),
TRUE ~ 0),
hidx_rothfusz = hidx_base - hidx_adj,
hidx_simple = 0.5 * (t2m_max_f + 61.0 + ((t2m_max_f-68.0)*1.2) + (relative_humidity*0.094)),
hidx = ifelse((hidx_simple +t2m_max_f)/2  < 80,
hidx_simple,
hidx_rothfusz)) %>%
dplyr::select(-c(hidx_base,hidx_adj)) %>%
dplyr::mutate(hidx_c = (hidx - 32)*5/9 )
saveRDS(fin_df,
paste0(data_filepath,
"working/all_elections_analysis.RDS"))
write_dta(fin_df %>%
dplyr::rename(poll_date = `Poll Date`,
poll_day = `Poll Day`),
paste0(data_filepath,
"working/all_elections_analysis.dta"))
