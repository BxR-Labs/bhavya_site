!State_Name %in% c("Telangana",
"Andhra_Pradesh") &
Election_Type == "State Assembly Election (AE)") ~ paste0(State_Name,"-",
Constituency_No),
(Year %in% c(2019) &
State_Name == "Telangana" &
Election_Type == "Lok Sabha Election (GE) (AC Segment Wise)") |
(Year >= 2014 &
State_Name == "Telangana" &
Election_Type == "State Assembly Election (AE)") ~ paste0("Andhra_Pradesh-",
Constituency_No),
(Year %in% c(2019) &
State_Name == "Andhra_Pradesh" &
Election_Type == "Lok Sabha Election (GE) (AC Segment Wise)") |
(Year >= 2014 &
State_Name == "Andhra_Pradesh" &
Election_Type == "State Assembly Election (AE)") ~ paste0("Andhra_Pradesh-",
AP_ac_id),#compared lists to identify pattern
Year == 2004 ~ paste0(State_Name,"-",
AC_No_2012),
TRUE ~ NA_character_),
standard_ac_id = case_when((Year %in% c(2009,2014) &
Election_Type == "Lok Sabha Election (GE) (AC Segment Wise)") |
(Year < 2014 &
Election_Type == "State Assembly Election (AE)") ~ Constituency_No,
(Year %in% c(2019) &
!State_Name %in% c("Telangana",
"Andhra_Pradesh") &
Election_Type == "Lok Sabha Election (GE) (AC Segment Wise)") |
(Year >= 2014 &
!State_Name %in% c("Telangana",
"Andhra_Pradesh") &
Election_Type == "State Assembly Election (AE)") ~ Constituency_No,
(Year %in% c(2019) &
State_Name == "Telangana" &
Election_Type == "Lok Sabha Election (GE) (AC Segment Wise)") |
(Year >= 2014 &
State_Name == "Telangana" &
Election_Type == "State Assembly Election (AE)") ~ Constituency_No,
(Year %in% c(2019) &
State_Name == "Andhra_Pradesh" &
Election_Type == "Lok Sabha Election (GE) (AC Segment Wise)") |
(Year >= 2014 &
State_Name == "Andhra_Pradesh" &
Election_Type == "State Assembly Election (AE)") ~ AP_ac_id,#compared lists to identify pattern
Year == 2004 ~ AC_No_2012,
TRUE ~ NA_real_),
panel_pc_id = case_when((Year %in% c(2009,2014)  &
Election_Type == "Lok Sabha Election (GE) (AC Segment Wise)") |
(Year < 2014 &
Election_Type == "State Assembly Election (AE)") ~ paste0(State_Name,"-",
PC_No),
(Year %in% c(2019) &
!State_Name %in% c("Telangana",
"Andhra_Pradesh") &
Election_Type == "Lok Sabha Election (GE) (AC Segment Wise)") |
(Year >= 2014 &
!State_Name %in% c("Telangana",
"Andhra_Pradesh") &
Election_Type == "State Assembly Election (AE)") ~ paste0(State_Name,"-",
PC_No),
(Year %in% c(2019) &
State_Name == "Telangana" &
Election_Type == "Lok Sabha Election (GE) (AC Segment Wise)") |
(Year >= 2014 &
State_Name == "Telangana" &
Election_Type == "State Assembly Election (AE)") ~ paste0("Andhra_Pradesh-",
PC_No),
(Year %in% c(2019) &
State_Name == "Andhra_Pradesh" &
Election_Type == "Lok Sabha Election (GE) (AC Segment Wise)") |
(Year >= 2014 &
State_Name == "Andhra_Pradesh" &
Election_Type == "State Assembly Election (AE)") ~ paste0("Andhra_Pradesh-",
AP_pc_id), #compared lists to identify pattern
Year == 2004 ~ paste0(State_Name,"-",
PC_No_2012),
TRUE ~ NA_character_),
standard_pc_id = case_when((Year %in% c(2009,2014)  &
Election_Type == "Lok Sabha Election (GE) (AC Segment Wise)") |
(Year < 2014 &
Election_Type == "State Assembly Election (AE)") ~ PC_No,
(Year %in% c(2019) &
!State_Name %in% c("Telangana",
"Andhra_Pradesh") &
Election_Type == "Lok Sabha Election (GE) (AC Segment Wise)") |
(Year >= 2014 &
!State_Name %in% c("Telangana",
"Andhra_Pradesh") &
Election_Type == "State Assembly Election (AE)") ~ PC_No,
(Year %in% c(2019) &
State_Name == "Telangana" &
Election_Type == "Lok Sabha Election (GE) (AC Segment Wise)") |
(Year >= 2014 &
State_Name == "Telangana" &
Election_Type == "State Assembly Election (AE)") ~ PC_No,
(Year %in% c(2019) &
State_Name == "Andhra_Pradesh" &
Election_Type == "Lok Sabha Election (GE) (AC Segment Wise)") |
(Year >= 2014 &
State_Name == "Andhra_Pradesh" &
Election_Type == "State Assembly Election (AE)") ~ AP_pc_id, #compared lists to identify pattern
Year == 2004 ~ PC_No_2012,
TRUE ~ NA_real_)) %>%
dplyr::select(-starts_with("AP_"))
table(is.na(fin_df$panel_ac_id),fin_df$State_Name)
table(is.na(fin_df$panel_ac_id),fin_df$Year)
# Drop information on J&K ACs 88,89,90 because the situation there is fairly complicated and they do not have representation in the legislative assembly
