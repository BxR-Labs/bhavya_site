fin_df <- fin_df %>%
dplyr::mutate(AP_pc_id = case_when(Year >= 2019 &
State_Name == "Andhra_Pradesh" &
Election_Type == "Lok Sabha Election (GE) (AC Segment Wise)" ~ as.numeric(PC_No) + 17,
Year >= 2014 &
State_Name == "Andhra_Pradesh" &
Election_Type == "State Assembly Election (AE)" ~ as.numeric(PC_No) + 17,
TRUE ~ NA),
AP_ac_id = case_when(Year >= 2019 &
State_Name == "Andhra_Pradesh"  &
Election_Type == "Lok Sabha Election (GE) (AC Segment Wise)" ~ as.numeric(Constituency_No) + 119,
Year >= 2014 &
State_Name == "Andhra_Pradesh"  &
Election_Type == "State Assembly Election (AE)" ~ as.numeric(Constituency_No) + 119,
TRUE ~ NA)) %>%
dplyr::mutate(panel_ac_id = case_when((Year %in% c(2009,2014)  &
Election_Type == "Lok Sabha Election (GE) (AC Segment Wise)") |
